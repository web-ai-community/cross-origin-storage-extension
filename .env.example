# Copy to .env (gitignored, never commit it) and fill in the App Store
# Connect API private key for upload-safari-build.sh.

# Paste the full contents of your AuthKey_<KEY_ID>.p8 file here, quoted:
ASC_API_KEY="-----BEGIN PRIVATE KEY-----
...
-----END PRIVATE KEY-----"

# Only needed if these ever change (e.g. rotating the key) -- otherwise
# upload-safari-build.sh already defaults to this project's values:
# ASC_KEY_ID=B78MTCSY2V
# ASC_ISSUER_ID=69a6de6f-b54e-47e3-e053-5b8c7c11a4d1
# ASC_TEAM_ID=58S46496RD
