{
  "manifest_version": 3,
  "name": "Cross-Origin Storage",
  "version": "0.1.20",
  "description": "Implements the proposed Cross-Origin Storage API for sharing files across sites with consent.",
  "options_page": "options.html",
  "permissions": ["storage", "unlimitedStorage", "tabs"],
  "host_permissions": ["https://raw.githubusercontent.com/*"],
  "background": {
    "page": "background.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "logo-cos.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://localhost/*", "http://*.test/*", "http://*.a.test/*"],
      "js": ["main-world.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["https://*/*", "http://localhost/*", "http://*.test/*", "http://*.a.test/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["relay-extension.html"],
      "matches": ["https://*/*", "http://localhost/*", "http://*.test/*", "http://*.a.test/*"]
    }
  ],
  "icons": {
    "512": "logo-cos.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{133c330c-eac1-4aba-9ec0-e52d4d09392a}",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}
