{
  "permissions": ["storage", "unlimitedStorage", "offscreen", "tabs"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://localhost:*/*", "http://*.test/*", "http://*.a.test/*"],
      "js": ["main-world.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["https://*/*", "http://localhost:*/*", "http://*.test/*", "http://*.a.test/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["relay-extension.html"],
      "matches": ["https://*/*", "http://localhost:*/*", "http://*.test/*", "http://*.a.test/*"]
    }
  ]
}
