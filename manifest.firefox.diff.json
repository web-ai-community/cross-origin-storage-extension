{
  "permissions": ["storage", "unlimitedStorage", "tabs"],
  "background": {
    "page": "background.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://localhost/*", "http://*.test/*", "http://*.a.test/*"],
      "js": ["main-world.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["https://*/*", "http://localhost/*", "http://*.test/*", "http://*.a.test/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["relay-extension.html"],
      "matches": ["https://*/*", "http://localhost/*", "http://*.test/*", "http://*.a.test/*"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "{133c330c-eac1-4aba-9ec0-e52d4d09392a}",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}
