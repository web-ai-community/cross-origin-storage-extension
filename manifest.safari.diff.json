{
  "permissions": ["storage", "unlimitedStorage", "tabs"],
  "background": {
    "page": "background.html",
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://localhost/*", "http://*.test/*", "http://*.a.test/*"],
      "js": ["main-world.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["https://*/*", "http://localhost/*", "http://*.test/*", "http://*.a.test/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["relay-extension.html"],
      "matches": ["https://*/*", "http://localhost/*", "http://*.test/*", "http://*.a.test/*"]
    }
  ],
  "browser_specific_settings": {
    "safari": {
      "strict_min_version": "18.0"
    }
  }
}
