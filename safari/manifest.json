{
  "manifest_version": 3,
  "name": "Cross-Origin Storage",
  "version": "0.1.19",
  "description": "Implements the proposed Cross-Origin Storage API, letting sites share files with your consent for a faster and more efficient web.",
  "options_page": "options.html",
  "host_permissions": [
    "https://raw.githubusercontent.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "logo-cos.png"
  },
  "icons": {
    "512": "logo-cos.png"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "tabs"
  ],
  "background": {
    "page": "background.html",
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://localhost/*",
        "http://*.test/*",
        "http://*.a.test/*"
      ],
      "js": [
        "main-world.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "https://*/*",
        "http://localhost/*",
        "http://*.test/*",
        "http://*.a.test/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "relay-extension.html"
      ],
      "matches": [
        "https://*/*",
        "http://localhost/*",
        "http://*.test/*",
        "http://*.a.test/*"
      ]
    }
  ],
  "browser_specific_settings": {
    "safari": {
      "strict_min_version": "18.0"
    }
  }
}
